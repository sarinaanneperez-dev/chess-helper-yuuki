{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "Yuuki",
  "version": "1.1",
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*"
      ],
      "css": [
        "style.css"
      ],
      "js": [
        "engine.js",
        "ui.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "yuuki-engine.js"
      ],
      "matches": [
        "https://www.chess.com/*"
      ]
    }
  ]
}